{
    "name": "robotateme/psr7-whatsapp-media-crypto",
    "description": "WhatsApp media encryption helpers built on PSR-7 streams",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Oem\\Psr7WhatsappMediaCrypto\\": "src/",
            "Oem\\Psr7WhatsappMediaCrypto\\Test\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "robotateme",
            "email": "jarwork884@gmail.com"
        }
    ],
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.9",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "vimeo/psalm": "6.0.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:performance": "vendor/bin/phpunit -c phpunit.performance.xml",
        "bench:stream": "php bench/stream_benchmark.php"
    }
}
